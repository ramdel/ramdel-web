# Supply chain hardening — block postinstall/preinstall script execution
# Prevents malicious packages from running arbitrary OS commands during npm install
# Reference: https://www.nodejs-security.com/blog/npm-ignore-scripts-best-practices-as-security-mitigation-for-malicious-packages
#
# If a package requires scripts (e.g. native addons), install explicitly with:
#   npm install --ignore-scripts=false <package>
ignore-scripts=true
